# Copy this file to .env.local only when you wire Supabase into the app.
# The current Pace AI landing/demo runs without Supabase env vars.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Edge Function secrets are set with `npm run ai:secret`, not exposed to Vite.
# npm run ai:secret -- GEMINI_API_KEY=your-gemini-key
# npm run ai:secret -- AI_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
